        <mxCell id="e5" value="返回 Top-K 记录" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#000000;strokeWidth=2;fontSize=14;" edge="1" parent="1" source="collection" target="query">
          <mxGeometry relative="1" as="geometry">
