        <mxCell id="e3" value="包含" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=diamondThin;strokeColor=#000000;strokeWidth=2;fontSize=14;" edge="1" parent="1" source="record" target="metadata">
          <mxGeometry relative="1" as="geometry"/>
