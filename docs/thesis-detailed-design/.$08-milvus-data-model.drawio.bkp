        <mxCell id="e4" value="检索" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#000000;strokeWidth=2;fontSize=14;" edge="1" parent="1" source="query" target="collection">
          <mxGeometry relative="1" as="geometry">
